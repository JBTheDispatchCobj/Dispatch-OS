{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Entity Resolution Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "resolution_id",
    "tenant_id",
    "entity_type",
    "candidate_ids",
    "decision",
    "score",
    "status"
  ],
  "properties": {
    "resolution_id": {
      "type": "string",
      "pattern": "^RES-[A-Z0-9-]+$"
    },
    "tenant_id": {
      "type": "string"
    },
    "entity_type": {
      "type": "string"
    },
    "candidate_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "decision": {
      "type": "string",
      "enum": [
        "match",
        "no_match",
        "possible_match",
        "merge",
        "cannot_link"
      ]
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "negative_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "automatic",
        "review_required",
        "approved",
        "rejected",
        "reversed"
      ]
    },
    "reviewer_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "rationale": {
      "type": "string"
    },
    "undo_reference": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "classification": {
      "type": "string",
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted",
        "regulated"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low",
        "unknown"
      ]
    },
    "freshness": {
      "type": "string",
      "enum": [
        "current",
        "aging",
        "stale",
        "unknown"
      ]
    },
    "status": {
      "type": "string",
      "minLength": 1
    }
  }
}
