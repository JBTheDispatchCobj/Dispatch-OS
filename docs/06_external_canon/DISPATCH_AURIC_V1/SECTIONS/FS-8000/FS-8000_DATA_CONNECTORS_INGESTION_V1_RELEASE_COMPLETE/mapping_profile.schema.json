{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Mapping Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mapping_profile_id",
    "source_schema",
    "target_object_type",
    "version",
    "status",
    "field_mappings"
  ],
  "properties": {
    "mapping_profile_id": {
      "type": "string",
      "pattern": "^MAP-[A-Z0-9-]+$"
    },
    "source_schema": {
      "type": "string"
    },
    "target_object_type": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "effective_at": {
      "anyOf": [
        {
          "$ref": "#/$defs/timestamp"
        },
        {
          "type": "null"
        }
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "test",
        "review",
        "approved",
        "active",
        "deprecated",
        "retired"
      ]
    },
    "field_mappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_path",
          "target_path",
          "mapping_type"
        ],
        "properties": {
          "source_path": {
            "type": "string"
          },
          "target_path": {
            "type": "string"
          },
          "mapping_type": {
            "type": "string",
            "enum": [
              "direct",
              "lookup",
              "transform",
              "derive",
              "constant",
              "ignore"
            ]
          },
          "transformation_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "required": {
            "type": "boolean"
          },
          "default": {
            "type": [
              "string",
              "number",
              "boolean",
              "null"
            ]
          }
        }
      }
    },
    "owner_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "approved_by": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "classification": {
      "type": "string",
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted",
        "regulated"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low",
        "unknown"
      ]
    },
    "freshness": {
      "type": "string",
      "enum": [
        "current",
        "aging",
        "stale",
        "unknown"
      ]
    },
    "status": {
      "type": "string",
      "minLength": 1
    }
  }
}
