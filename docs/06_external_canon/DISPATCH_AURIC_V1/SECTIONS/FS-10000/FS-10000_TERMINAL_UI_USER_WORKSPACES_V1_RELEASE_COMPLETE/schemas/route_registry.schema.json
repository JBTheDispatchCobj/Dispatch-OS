{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "route_registry.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "routes"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "route_id",
          "path",
          "page_contract_id",
          "required_capability"
        ]
      }
    }
  }
}