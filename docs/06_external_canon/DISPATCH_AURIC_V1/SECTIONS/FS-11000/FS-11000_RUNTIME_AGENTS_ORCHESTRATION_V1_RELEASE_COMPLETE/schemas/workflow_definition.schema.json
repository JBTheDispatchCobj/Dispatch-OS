{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WorkflowDefinition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workflow_id",
    "version",
    "name",
    "status",
    "trigger_types",
    "steps",
    "completion_policy"
  ],
  "properties": {
    "workflow_id": {
      "type": "string",
      "pattern": "^WF-[A-Z0-9_-]+$"
    },
    "version": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "status": {
      "enum": [
        "draft",
        "approved",
        "active",
        "deprecated",
        "retired"
      ]
    },
    "trigger_types": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "step_definition.schema.json"
      }
    },
    "completion_policy": {
      "type": "object"
    },
    "required_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "approval_gates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "slo": {
      "type": "object"
    }
  }
}