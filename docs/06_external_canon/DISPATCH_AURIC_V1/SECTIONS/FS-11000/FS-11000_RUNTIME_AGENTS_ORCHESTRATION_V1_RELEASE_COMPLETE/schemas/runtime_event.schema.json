{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RuntimeEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_type",
    "schema_version",
    "tenant_id",
    "subject_ref",
    "correlation_id",
    "occurred_at",
    "recorded_at",
    "payload_ref"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "pattern": "^EVT-"
    },
    "event_type": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "subject_ref": {
      "type": "string"
    },
    "correlation_id": {
      "type": "string"
    },
    "causation_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "classification": {
      "type": "string"
    },
    "payload_ref": {
      "type": "string"
    },
    "deduplication_key": {
      "type": "string"
    }
  }
}