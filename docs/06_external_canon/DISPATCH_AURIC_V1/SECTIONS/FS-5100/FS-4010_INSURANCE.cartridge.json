  "supported_workflows": [
    {
      "workflow": "Risk Discovery",
      "description": "Identify household, business, income, liability, collateral, estate, and continuity risks.",
      "required_objects": [
        "Policyholder",
        "RiskProfile",
        "Policy",
        "Coverage"
      ],
      "outputs": [
        "Protection gap summary",
        "Product category recommendations",
        "Referral or quote task"
      ],
      "approval_gates": [
        "licensed_producer_review_before_recommendation"
      ]
    },
    {
      "workflow": "Quote-to-Bind",
      "description": "Route discovery, quote, application, underwriting, proposal, approval, and policy issuance.",
      "required_objects": [
        "Policyholder",
        "Quote",
        "Application",
        "UnderwritingFile",
        "Policy"
      ],
      "outputs": [
        "Quote comparison",
        "Application package",
        "Bound policy"
      ],
      "approval_gates": [
        "licensed_producer_approval",
        "carrier_underwriting_approval",
        "customer_acceptance"
      ]
    },
    {
      "workflow": "Policy Issuance",
      "description": "Issue policy, collect premium, deliver documents, and preserve coverage evidence.",
      "required_objects": [
        "Policy",
        "Premium",
        "Coverage",
        "Document"
      ],
      "outputs": [
        "Issued policy",
        "Delivery evidence",
        "Billing setup"
      ],
      "approval_gates": [
        "carrier_or_authorized_agency_approval"
      ]
    },
    {
      "workflow": "Renewal Review",
      "description": "Review exposures, claims, coverage, carrier terms, premium, and retention risk.",
      "required_objects": [
        "Policy",
        "Renewal",
        "Claim",
        "Coverage"
      ],
      "outputs": [
        "Renewal comparison",
        "Coverage gap summary",
        "Client review package"
      ],
      "approval_gates": [
        "licensed_producer_review"
      ]
    },
    {
      "workflow": "Endorsement",
      "description": "Process policy changes, coverage updates, endorsements, and premium impacts.",
      "required_objects": [
        "Policy",
        "Endorsement",
        "Coverage",
        "Premium"
      ],
      "outputs": [
        "Approved endorsement",
        "Updated policy evidence",
        "Premium change"
      ],
      "approval_gates": [
        "carrier_or_authorized_agency_approval"
      ]
    },
    {
      "workflow": "Claim",
      "description": "Intake loss, review coverage, investigate, reserve, adjudicate, pay or deny, and close.",
      "required_objects": [
        "Claim",
        "Policy",
        "Coverage",
        "Evidence"
      ],
      "outputs": [
        "Claim file",
        "Status summary",
        "Payment or denial package",
        "Closure record"
      ],
      "approval_gates": [
        "authorized_claims_owner",
        "legal_or_compliance_review_if_denial_or_dispute"
      ]
    },
    {
      "workflow": "Commission Reconciliation",
      "description": "Match policy, premium, producer, agency, referral source, carrier statement, and payout.",
      "required_objects": [
        "Commission",
        "Premium",
        "Policy",
        "Producer"
      ],
      "outputs": [
        "Reconciliation report",
        "Exception queue",
        "Producer payout file"
      ],
      "approval_gates": [
        "finance_or_operations_approval"
      ]
    },
    {
      "workflow": "Producer Licensing",
      "description": "Verify license, appointment, CE, training, and product authority before activity.",
      "required_objects": [
        "Producer",
        "License",
        "Appointment",
        "TrainingRecord"
      ],
      "outputs": [
        "Authority status",
        "Exception list",
        "Renewal tasks"
      ],
      "approval_gates": [
        "insurance_compliance_approval"
      ]
    },
    {
      "workflow": "Credit Union / Bank Insurance Referral",
      "description": "Detect protection need, capture consent, route referral, track outcome, and attribute economics.",
      "required_objects": [
        "CustomerOrMember",
        "Referral",
        "InsuranceOpportunity",
        "Producer"
      ],
      "outputs": [
        "Referral brief",
        "Consent/disclosure record",
        "Outcome and revenue attribution"
      ],
      "approval_gates": [
        "referral_compliance_review",
        "licensed_producer_review"
      ]
    }
  ],
  "allowed_agents": [
    {
      "agent": "Insurance Opportunity Agent",
      "allowed_actions": [
        "detect_referral_triggers",
        "identify_product_categories",
        "prepare_opportunity_brief",
        "route_referral"
      ],
      "prohibited_actions": [
        "recommend_specific_policy_without_license",
        "bind_coverage",
        "make_final_suitability_determination"
      ]
    },
    {
      "agent": "Coverage Gap Agent",
      "allowed_actions": [
        "summarize_existing_coverage",
        "identify_unaddressed_risks",
        "prepare_review_checklist"
      ],
      "prohibited_actions": [
        "issue_final_recommendation",
        "represent_policy_terms_without_source"
      ]
    },
    {
      "agent": "Quote Prep Agent",
      "allowed_actions": [
        "collect_application_inputs",
        "prepare_carrier_ready_summary",
        "compare_quoted_terms",
        "flag_missing_evidence"
      ],
      "prohibited_actions": [
        "submit_without_authorization",
        "bind_policy",
        "alter_carrier_terms"
      ]
    },
    {
      "agent": "Renewal Review Agent",
      "allowed_actions": [
        "summarize_claims_and_exposures",
        "compare_current_and_renewal_terms",
        "flag_lapse_or_retention_risk"
      ],
      "prohibited_actions": [
        "accept_renewal",
        "change_coverage",
        "commit_to_customer"
      ]
    },
    {
      "agent": "Claim Intake Agent",
      "allowed_actions": [
        "capture_loss_notice",
        "classify_claim",
        "prepare_evidence_checklist",
        "draft_status_update"
      ],
      "prohibited_actions": [
        "approve_payment",
        "deny_claim",
        "make_final_coverage_determination"
      ]
    },
    {
      "agent": "Commission Reconciliation Agent",
      "allowed_actions": [
        "match_statements_to_policies",
        "calculate_splits",
        "identify_chargebacks",
        "draft_exception_report"
      ],
      "prohibited_actions": [
        "release_payment_without_approval",
        "change_compensation_terms"
      ]
    },
    {
      "agent": "Licensing Monitor",
      "allowed_actions": [
        "track_license_expiration",
        "track_CE",
        "verify_appointment_status",
        "flag_unauthorized_activity"
      ],
      "prohibited_actions": [
        "grant_authority",
        "override_license_requirement"
      ]
    },
    {
      "agent": "Suitability Review Agent",
      "allowed_actions": [
        "check_required_factors",
        "identify_missing_rationale",
        "prepare_supervisory_review package"
      ],
      "prohibited_actions": [
        "make_final_suitability_determination",
        "approve_replacement",
        "approve_annuity_sale"
      ]
    }
