      ]
    },
    {
      "agent": "Vendor Stack Agent",
      "allowed_actions": [
        "inventory_vendors",
        "map_system_dependencies",
        "flag_renewals",
        "identify_integration_constraints"
      ],
      "prohibited_actions": [
        "approve_vendor",
        "terminate_contract",
        "change_system_access"
      ]
    },
    {
      "agent": "Board Governance Agent",
      "allowed_actions": [
        "draft_board_summary",
        "track_decisions",
        "summarize_risks",
        "prepare_action_items"
      ],
      "prohibited_actions": [
        "release_board_packet_without_approval",
        "record_fake_minutes"
      ]
    },
    {
      "agent": "Regulatory Readiness Agent",
      "allowed_actions": [
        "map_obligations",
        "identify_evidence_gaps",
        "draft_readiness_summary",
        "route_compliance_tasks"
      ],
      "prohibited_actions": [
        "file_report",
        "send_regulator_response",
        "issue_final_compliance_conclusion"
      ]
    },
    {
      "agent": "Member Opportunity Agent",
      "allowed_actions": [
        "detect_wallet_expansion",
        "route_referrals",
        "generate_opportunity_brief",
        "prepare_consent_checklist"
      ],
      "prohibited_actions": [
        "provide_advice",
        "bind_insurance",
        "approve_loan",
        "execute_referral_without_required_consent"
      ]
    }
