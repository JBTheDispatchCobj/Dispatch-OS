  "purpose": "Deployable cartridge manifest for credit union institutional intelligence across members, products, CUSOs, vendors, governance, regulation, fintech pilots, and cooperative capital opportunities.",
  "cartridge_type": "domain_operating_cartridge",
  "status": "production_manifest",
  "strategic_lens": "Credit unions are member-owned financial institutions with a unique cooperative structure, regulatory profile, vendor ecosystem, CUSO optionality, and unrealized capacity to connect member needs, innovation, and institutional capital.",
  "primary_objects": [
    {
      "object": "CreditUnion",
      "role": "Root institution object for charter, field of membership, products, vendors, members, board, and regulatory context.",
      "required_fields": [
        "institution_id",
        "name",
        "charter",
        "field_of_membership",
        "assets",
        "members",
        "regulators",
        "CUSOs",
        "vendors",
        "products"
      ]
    },
    {
      "object": "Member",
      "role": "Member relationship object connecting eligibility, accounts, loans, needs, events, and opportunities.",
      "required_fields": [
        "member_id",
        "household",
        "accounts",
        "loans",
        "needs",
        "life_events",
        "eligibility",
        "opportunities"
      ]
    },
    {
      "object": "FieldOfMembership",
      "role": "Eligibility and membership boundary object.",
      "required_fields": [
        "fom_id",
        "eligibility_rules",
        "groups",
        "geography",
        "employer_links",
        "constraints"
      ]
    },
    {
      "object": "CUSO",
      "role": "Credit union service organization, investment, governance, and activity object.",
      "required_fields": [
        "cuso_id",
        "owners",
        "services",
        "investments",
        "governance",
        "compliance_status",
        "relationships"
      ]
    },
    {
      "object": "VendorStack",
      "role": "Core, digital, lending, compliance, payment, wealth, insurance, and fintech vendor inventory.",
      "required_fields": [
        "vendor_stack_id",
        "institution",
        "vendors",
        "systems",
        "contracts",
        "risk_tiers",
        "renewals",
        "integration_notes"
      ]
    },
    {
      "object": "MemberProduct",
      "role": "Credit union product or service offered to members.",
      "required_fields": [
        "product_id",
        "type",
        "eligibility",
        "pricing",
        "risk",
        "member_segment",
        "regulatory_profile"
      ]
    },
    {
      "object": "Board",
      "role": "Governance body for approvals, committees, minutes, policy oversight, and strategic priorities.",
      "required_fields": [
        "board_id",
        "members",
        "committees",
        "approvals",
        "minutes",
        "strategic_priorities"
      ]
    },
    {
      "object": "FintechPilot",
      "role": "Structured pilot opportunity connecting startup, CU, use case, vendor risk, compliance, success metrics, and board awareness.",
      "required_fields": [
        "pilot_id",
        "startup",
        "credit_union",
        "use_case",
        "data_flow",
        "success_metrics",
        "vendor_review",
        "approval_status"
      ]
    }
  ],
  "supported_workflows": [
    {
      "workflow": "Member Onboarding",
      "description": "Open and verify credit union member relationship.",
      "required_objects": [
        "Member",
        "FieldOfMembership",
        "Account"
      ],
      "outputs": [
        "Member profile",
        "Eligibility evidence"
      ],
      "approval_gates": [
        "operations_review",
        "compliance_review_if_exception"
      ]
    },
    {
      "workflow": "CUSO Review",
      "description": "Evaluate CUSO activity, authority, investment, ownership, risk, and governance.",
      "required_objects": [
        "CUSO",
        "Investment",
        "Policy",
        "Board"
      ],
      "outputs": [
        "CUSO memo",
        "Board evidence",
        "Risk/authority summary"
      ],
      "approval_gates": [
        "compliance_owner_approval",
        "board_or_committee_approval_if_material"
      ]
    },
    {
      "workflow": "Fintech Pilot Readiness",
      "description": "Assess fintech product fit, readiness, integration, vendor risk, compliance, and governance path for a CU pilot.",
      "required_objects": [
        "Startup",
        "CreditUnion",
        "VendorStack",
        "UseCase",
        "FintechPilot"
      ],
      "outputs": [
        "Readiness score",
        "Pilot plan",
        "Vendor checklist",
        "Board memo"
      ],
      "approval_gates": [
        "business_owner_approval",
        "vendor_risk_approval",
        "security_review",
        "compliance_review"
      ]
    },
    {
      "workflow": "Member Opportunity Detection",
      "description": "Identify product, mortgage, commercial, wealth, insurance, and lending opportunities from member context.",
      "required_objects": [
        "Member",
        "Household",
        "Product",
        "Opportunity"
      ],
      "outputs": [
        "Opportunity list",
        "Referral tasks",
        "Consent/disclosure checklist"
      ],
      "approval_gates": [
        "referral_compliance_review",
        "licensed_owner_review_when_needed"
      ]
    },
    {
      "workflow": "Board Governance Review",
      "description": "Prepare CU board/committee governance package for risks, policies, opportunities, and strategic actions.",
      "required_objects": [
        "Board",
        "Policy",
        "Risk",
        "Report",
        "KPI"
      ],
      "outputs": [
        "Board package",
        "Decision log",
        "Action items"
      ],
      "approval_gates": [
        "executive_owner_approval"
      ]
    },
    {
      "workflow": "Regulatory Readiness",
      "description": "Map CU obligations, policies, controls, evidence, exam readiness, and remediation.",
      "required_objects": [
        "Obligation",
        "Policy",
        "Control",
        "Evidence",
        "Examination"
      ],
      "outputs": [
        "Readiness report",
        "Evidence map",
        "Compliance dashboard"
      ],
      "approval_gates": [
        "compliance_owner_approval"
      ]
    }
  ],
  "allowed_agents": [
    {
      "agent": "Member Intelligence Agent",
      "allowed_actions": [
        "profile_members",
        "identify_product_gaps",
        "summarize_member_context",
        "detect_life_events"
      ],
      "prohibited_actions": [
        "open_account",
        "approve_credit",
        "make_final_suitability_determination"
      ]
    },
    {
      "agent": "Credit Union Readiness Agent",
      "allowed_actions": [
        "score_readiness",
        "identify_blockers",
        "summarize_institutional_context",
        "recommend_next_actions"
      ],
      "prohibited_actions": [
        "approve_product_launch",
        "approve_vendor",
        "make_final_compliance_determination"
      ]
    },
    {
      "agent": "CUSO Review Agent",
