  "purpose": "Deployable cartridge manifest for mortgage operating intelligence across borrower intake, document collection, underwriting support, disclosures, pipeline, closing, secondary readiness, compliance, and post-close quality control.",
  "cartridge_type": "domain_operating_cartridge",
  "status": "production_manifest",
  "strategic_lens": "Mortgage is a document-heavy, milestone-driven, compliance-sensitive production system where the institution must convert borrower/property facts into a fundable, compliant, saleable loan file.",
  "primary_objects": [
    {
      "object": "MortgageLoan",
      "role": "Root mortgage file and production object.",
      "required_fields": [
        "loan_id",
        "borrower",
        "property",
        "product_type",
        "loan_amount",
        "LTV",
        "DTI",
        "rate",
        "milestone",
        "status"
      ]
    },
    {
      "object": "Borrower",
      "role": "Consumer borrower profile for credit, income, assets, liabilities, and eligibility.",
      "required_fields": [
        "borrower_id",
        "name",
        "income",
        "assets",
        "liabilities",
        "credit_score",
        "documents",
        "risk_flags"
      ]
    },
    {
      "object": "Property",
      "role": "Collateral object for value, title, insurance, location, and occupancy.",
      "required_fields": [
        "property_id",
        "address",
        "value",
        "appraisal",
        "title",
        "insurance",
        "collateral_status"
      ]
    },
    {
      "object": "Condition",
      "role": "Underwriting, processing, closing, or post-close condition requiring evidence.",
      "required_fields": [
        "condition_id",
        "loan",
        "type",
        "description",
        "owner",
        "due_date",
        "status",
        "evidence"
      ]
    },
    {
      "object": "Disclosure",
      "role": "Mortgage disclosure timing and delivery evidence object.",
      "required_fields": [
        "disclosure_id",
        "loan",
        "type",
        "delivery_date",
        "timing_status",
        "evidence"
      ]
    },
    {
      "object": "RateLock",
      "role": "Pricing, lock expiration, extension, and fallout risk object.",
      "required_fields": [
        "lock_id",
        "loan",
        "rate",
        "price",
        "expiration",
        "investor",
        "fallout_risk"
      ]
    },
    {
      "object": "ClosingPackage",
      "role": "Clear-to-close, closing disclosure, docs, funding, and boarding package.",
      "required_fields": [
        "closing_id",
        "loan",
        "clear_to_close_status",
        "CD_status",
        "docs",
        "funding_status",
        "post_close_status"
      ]
    },
    {
      "object": "PostCloseQC",
      "role": "Post-close defect, compliance, salability, and investor readiness object.",
      "required_fields": [
        "qc_id",
        "loan",
        "review_date",
        "defects",
        "severity",
        "corrections",
        "saleability_status"
      ]
    }
  ],
  "supported_workflows": [
    {
      "workflow": "Mortgage Application Intake",
      "description": "Create file and collect borrower/property data.",
      "required_objects": [
        "Borrower",
        "MortgageLoan",
        "Property"
      ],
      "outputs": [
        "Application package",
        "Initial missing document list"
      ],
      "approval_gates": [
        "MLO_or_operations_review"
      ]
    },
    {
      "workflow": "Document Collection",
      "description": "Collect, classify, validate, and clear borrower/property conditions.",
      "required_objects": [
        "Condition",
        "Document",
        "Evidence",
        "Borrower",
        "Property"
      ],
      "outputs": [
        "Cleared conditions",
        "Outstanding item list"
      ],
      "approval_gates": [
        "processor_review",
        "underwriter_review_if_condition_sensitive"
      ]
    },
    {
      "workflow": "Processing and Underwriting",
      "description": "Validate credit, income, assets, property, eligibility, and investor/program requirements.",
      "required_objects": [
        "MortgageLoan",
        "Borrower",
        "Property",
        "Condition"
      ],
      "outputs": [
        "Underwriting decision support",
        "Condition list",
        "Risk flags"
      ],
      "approval_gates": [
        "underwriter_approval",
        "credit_or_policy_exception_review"
      ]
    },
    {
      "workflow": "Disclosure Timing Review",
      "description": "Prepare and monitor mortgage disclosures and timing evidence.",
      "required_objects": [
        "Disclosure",
        "LoanEstimate",
        "ClosingDisclosure",
        "MortgageLoan"
      ],
      "outputs": [
        "Disclosure evidence",
        "Timing exception report"
      ],
      "approval_gates": [
        "compliance_review_if_exception"
      ]
    },
    {
      "workflow": "Closing and Funding",
      "description": "Clear to close, prepare documents, fund, board, and archive the loan.",
      "required_objects": [
        "MortgageLoan",
        "ClosingPackage",
        "Disclosure",
        "Condition"
      ],
      "outputs": [
        "Funded loan",
        "Closing package",
        "Boarding evidence"
      ],
      "approval_gates": [
        "clear_to_close_approval",
        "funding_authorization",
        "closing_review"
      ]
    },
    {
      "workflow": "Post-Close QC",
      "description": "Review closed file for defects, compliance exceptions, and saleability.",
      "required_objects": [
        "MortgageLoan",
        "PostCloseQC",
        "Document",
        "Evidence"
      ],
      "outputs": [
        "QC report",
        "Defect cure list",
        "Saleability status"
      ],
      "approval_gates": [
        "QC_manager_review",
        "secondary_or_compliance_review_if_material"
      ]
    }
  ],
  "allowed_agents": [
    {
      "agent": "Mortgage File Intake Agent",
      "allowed_actions": [
        "create_file_summary",
        "identify_required_fields",
        "draft_intake_checklist",
        "flag_missing_application_data"
      ],
      "prohibited_actions": [
        "approve_application",
        "issue_final_loan_terms",
        "commit_to_borrower"
      ]
    },
    {
      "agent": "Document Collection Agent",
      "allowed_actions": [
        "classify_documents",
        "match_documents_to_conditions",
        "flag_missing_items",
        "prepare_borrower_document_request"
      ],
      "prohibited_actions": [
        "clear_sensitive_conditions_without_review",
        "alter_source_documents"
      ]
    },
    {
      "agent": "Condition Clearing Agent",
      "allowed_actions": [
        "track_conditions",
