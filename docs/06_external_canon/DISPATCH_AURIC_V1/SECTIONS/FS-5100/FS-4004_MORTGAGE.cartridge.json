        "make_final_compliance_determination"
      ]
    },
    {
      "agent": "Underwriting Support Agent",
      "allowed_actions": [
        "summarize_credit_income_asset_property_evidence",
        "identify_risk_flags",
        "draft_underwriting_summary"
      ],
      "prohibited_actions": [
        "approve_loan",
        "deny_loan",
        "override_investor_guidelines"
      ]
    },
    {
      "agent": "Rate Lock Monitor",
      "allowed_actions": [
        "track_lock_expiration",
        "flag_extension_risk",
        "summarize_pricing_or_fallout_risk"
      ],
      "prohibited_actions": [
        "lock_rate",
        "change_pricing",
        "commit_terms"
      ]
    },
    {
      "agent": "Closing Checklist Agent",
      "allowed_actions": [
        "track_clear_to_close_items",
        "prepare_closing_package_status",
        "flag_funding_blockers"
      ],
      "prohibited_actions": [
        "authorize_funding",
        "release_docs_without_approval"
      ]
    },
    {
      "agent": "Post-Close QC Agent",
      "allowed_actions": [
        "classify_defects",
        "draft_QC_summary",
        "track_cures",
        "flag_saleability_risk"
      ],
      "prohibited_actions": [
        "finalize_QC_pass_fail_without_review",
        "sell_loan"
      ]
    }
