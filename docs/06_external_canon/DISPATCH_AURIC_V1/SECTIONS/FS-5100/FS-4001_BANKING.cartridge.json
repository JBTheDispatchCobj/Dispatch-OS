        "vendors",
        "risk"
      ]
    }
  ],
  "supported_workflows": [
    {
      "workflow": "Customer Onboarding",
      "description": "Open and verify new retail/business relationship.",
      "required_objects": [
        "CustomerRelationship",
        "Account",
        "KYC/KYB Evidence"
      ],
      "outputs": [
        "Account opening package",
        "Compliance evidence"
      ],
      "approval_gates": [
        "operations_review",
        "compliance_review_if_exception"
      ]
    },
    {
      "workflow": "Deposit Account Opening",
      "description": "Create and fund deposit account.",
      "required_objects": [
        "CustomerRelationship",
        "DepositAccount",
        "Disclosure"
      ],
      "outputs": [
        "Opened account",
        "Disclosure evidence"
      ],
      "approval_gates": [
        "operations_review"
      ]
    },
    {
      "workflow": "Loan Origination",
      "description": "Intake, underwrite, approve, close, and board loan.",
      "required_objects": [
        "Borrower",
        "Loan",
        "Collateral",
        "CreditMemo"
      ],
      "outputs": [
        "Booked loan",
        "Credit file"
      ],
      "approval_gates": [
        "credit_authority_approval",
        "closing_review"
      ]
    },
    {
      "workflow": "Treasury Implementation",
      "description": "Map payment flows and implement treasury services.",
      "required_objects": [
        "BusinessCustomer",
        "TreasuryService",
        "PaymentFlow"
      ],
      "outputs": [
        "Treasury setup",
        "Implementation checklist"
      ],
      "approval_gates": [
        "treasury_operations_approval",
        "security_review_if_needed"
      ]
    },
    {
      "workflow": "Complaint Management",
      "description": "Intake, classify, investigate, respond, and close complaints.",
      "required_objects": [
        "Complaint",
        "CustomerRelationship",
        "Evidence"
      ],
      "outputs": [
        "Response",
        "Complaint log"
      ],
      "approval_gates": [
        "compliance_review",
        "legal_review_if_escalated"
      ]
    },
    {
      "workflow": "Board Reporting",
      "description": "Prepare executive/board banking performance report.",
      "required_objects": [
        "KPI",
        "Report",
        "Committee"
      ],
      "outputs": [
        "Board packet",
        "Action items"
      ],
      "approval_gates": [
        "executive_owner_approval"
      ]
    }
  ],
  "allowed_agents": [
    {
      "agent": "Customer Relationship Agent",
      "allowed_actions": [
        "profile_relationships",
        "identify_product_gaps",
        "summarize_customer_context",
        "prepare_relationship_brief"
      ],
      "prohibited_actions": [
        "approve_account",
        "make_final_compliance_determination",
        "send_external_commitment"
      ]
    },
    {
      "agent": "Deposit Product Agent",
      "allowed_actions": [
        "summarize_deposit_mix",
        "detect_pricing_or_retention_issues",
        "draft_deposit_dashboard_commentary"
      ],
      "prohibited_actions": [
        "change_rate",
        "approve_product_terms",
        "commit_to_customer"
      ]
    },
    {
      "agent": "Loan Origination Agent",
      "allowed_actions": [
        "intake_loan_request",
        "identify_missing_documents",
        "draft_credit_file_summary",
        "route_to_credit_authority"
      ],
      "prohibited_actions": [
        "approve_credit",
        "waive_conditions",
        "fund_loan"
      ]
    },
    {
      "agent": "Treasury Services Agent",
      "allowed_actions": [
        "map_payment_flows",
        "recommend_treasury_options",
        "draft_implementation_checklist"
      ],
      "prohibited_actions": [
        "execute_contract",
        "open_service_without_approval"
      ]
    },
    {
      "agent": "Branch Performance Agent",
      "allowed_actions": [
        "summarize_branch_KPIs",
        "identify_local_market_opportunities",
        "flag_service_exceptions"
      ],
      "prohibited_actions": [
        "change_staffing",
        "approve_branch_actions"
      ]
    },
    {
      "agent": "Digital Channel Agent",
      "allowed_actions": [
        "summarize_digital_usage",
        "flag_availability_or_vendor_issues",
        "identify_adoption_opportunities"
      ],
      "prohibited_actions": [
        "change_system_settings",
        "approve_vendor_changes"
      ]
    },
    {
      "agent": "Complaint Management Agent",
      "allowed_actions": [
        "classify_complaint",
        "summarize_evidence",
        "draft_response_for_review",
        "track_resolution"
      ],
      "prohibited_actions": [
        "issue_final_response_without_approval",
        "admit_liability"
      ]
    },
    {
      "agent": "Board Reporting Agent",
      "allowed_actions": [
        "draft_board_packet",
        "summarize_KPIs",
        "flag_governance_actions"
      ],
      "prohibited_actions": [
        "release_board_packet_without_approval",
        "invent_KPIs"
      ]
    }
  ],
