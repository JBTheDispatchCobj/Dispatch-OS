        "summarize_collateral",
        "compare_value_to_exposure",
        "flag_perfection_or_insurance_gaps"
      ],
      "prohibited_actions": [
        "approve_collateral_release",
        "finalize_appraisal_value"
      ]
    },
    {
      "agent": "Annual Review Agent",
      "allowed_actions": [
        "draft_annual_review",
        "summarize_financial_trends",
        "identify_missing_reporting"
      ],
      "prohibited_actions": [
        "approve_annual_review",
        "change_risk_rating_final"
      ]
    },
    {
      "agent": "Workout Strategy Agent",
      "allowed_actions": [
        "summarize_default",
