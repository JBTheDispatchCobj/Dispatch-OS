  "purpose": "Deployable cartridge manifest for commercial banking intelligence across borrowers, credit facilities, treasury services, covenants, collateral, monitoring, relationship profitability, and workouts.",
  "cartridge_type": "domain_operating_cartridge",
  "status": "production_manifest",
  "strategic_lens": "Commercial banking is relationship finance. Credit, deposits, treasury, collateral, covenants, borrower operations, and risk monitoring should be understood as one institutional relationship, not isolated products.",
  "primary_objects": [
    {
      "object": "CommercialBorrower",
      "role": "Root business borrower and relationship profile.",
      "required_fields": [
        "borrower_id",
        "legal_name",
        "industry",
        "NAICS",
        "ownership",
        "revenue",
        "EBITDA",
        "cash_flow",
        "risk_rating",
        "relationship_manager"
      ]
    },
    {
      "object": "CommercialLoan",
      "role": "Commercial credit exposure, structure, collateral, pricing, and repayment object.",
      "required_fields": [
        "loan_id",
        "borrower",
        "facility_type",
        "amount",
        "purpose",
        "repayment_source",
        "collateral",
        "covenants",
        "risk_rating",
        "status"
      ]
    },
    {
      "object": "CreditMemo",
      "role": "Credit decision support object.",
      "required_fields": [
        "memo_id",
        "borrower",
        "request",
        "financial_analysis",
        "structure",
        "risks",
        "mitigants",
        "approval_recommendation"
      ]
    },
    {
      "object": "Collateral",
      "role": "Assets securing a commercial facility.",
      "required_fields": [
        "collateral_id",
        "type",
        "value",
        "valuation_source",
        "lien_position",
        "perfection_status",
        "coverage_ratio"
      ]
    },
    {
      "object": "Covenant",
      "role": "Contractual performance, reporting, and control obligation.",
      "required_fields": [
        "covenant_id",
        "facility",
        "metric",
        "threshold",
        "frequency",
        "evidence",
        "status",
        "exceptions"
      ]
    },
    {
      "object": "TreasuryRelationship",
      "role": "Payment flow, deposit, fee-income, and fraud-control service object.",
      "required_fields": [
        "relationship_id",
        "customer",
        "payment_flows",
        "services",
        "volumes",
        "fees",
        "fraud_controls",
        "implementation_status"
      ]
    },
    {
      "object": "AnnualReview",
      "role": "Periodic borrower and facility review object.",
      "required_fields": [
        "review_id",
        "borrower",
        "period",
        "financials",
        "covenants",
        "risk_rating",
        "relationship_profitability",
        "recommendation"
      ]
    },
    {
      "object": "WorkoutPlan",
      "role": "Distressed borrower strategy and recovery object.",
      "required_fields": [
        "workout_id",
        "borrower",
        "default_type",
        "collateral",
        "strategy",
        "milestones",
        "recovery_estimate",
        "status"
      ]
    }
  ],
  "supported_workflows": [
    {
      "workflow": "Commercial Credit Underwriting",
      "description": "Analyze borrower, financials, collateral, repayment source, covenants, and structure for credit approval.",
      "required_objects": [
        "CommercialBorrower",
        "CommercialLoan",
        "Collateral",
        "CreditMemo"
      ],
      "outputs": [
        "Credit memo",
        "Approval package",
        "Missing evidence list"
      ],
      "approval_gates": [
        "credit_authority_approval",
        "policy_exception_review_if_needed"
      ]
    },
    {
      "workflow": "Annual Review",
      "description": "Review commercial borrower financials, covenants, relationship performance, and risk rating.",
      "required_objects": [
        "CommercialBorrower",
        "AnnualReview",
        "Financials",
        "Covenant"
      ],
      "outputs": [
        "Annual review memo",
        "Risk rating update",
        "Relationship action plan"
      ],
      "approval_gates": [
        "credit_review_approval"
      ]
    },
    {
      "workflow": "Covenant Monitoring",
      "description": "Collect evidence and test commercial loan covenants.",
      "required_objects": [
        "Covenant",
        "ComplianceCertificate",
        "Financials",
        "CommercialLoan"
      ],
      "outputs": [
        "Pass/fail status",
        "Exception report",
        "Waiver/escalation recommendation"
      ],
      "approval_gates": [
        "credit_authority_approval_for_waivers"
      ]
    },
    {
      "workflow": "Treasury Assessment",
      "description": "Map commercial customer payment flows and recommend treasury products.",
      "required_objects": [
        "CommercialBorrower",
        "TreasuryRelationship",
        "PaymentFlow"
      ],
      "outputs": [
        "Treasury proposal",
        "Implementation plan",
        "Fraud controls checklist"
      ],
      "approval_gates": [
        "treasury_operations_approval",
        "security_review_if_integration"
      ]
    },
    {
      "workflow": "Portfolio Watchlist",
      "description": "Identify, classify, and manage deteriorating commercial credits.",
      "required_objects": [
        "CommercialLoan",
        "CommercialBorrower",
        "Risk",
        "AnnualReview"
      ],
      "outputs": [
        "Watchlist action plan",
        "Risk migration summary",
        "Monitoring tasks"
      ],
      "approval_gates": [
        "credit_risk_review"
      ]
    },
    {
      "workflow": "Workout Review",
      "description": "Create strategy for distressed commercial borrower, default, forbearance, collateral, and recovery.",
      "required_objects": [
        "WorkoutPlan",
        "Default",
        "Collateral",
        "CommercialBorrower"
      ],
      "outputs": [
        "Workout memo",
        "Recovery plan",
        "Approval actions"
      ],
      "approval_gates": [
        "credit_authority_approval",
        "legal_review_if_needed"
      ]
    }
  ],
  "allowed_agents": [
    {
      "agent": "Commercial Credit Analyst",
      "allowed_actions": [
        "analyze_financials",
        "summarize_borrower",
        "identify_risks",
        "draft_credit_analysis"
      ],
      "prohibited_actions": [
