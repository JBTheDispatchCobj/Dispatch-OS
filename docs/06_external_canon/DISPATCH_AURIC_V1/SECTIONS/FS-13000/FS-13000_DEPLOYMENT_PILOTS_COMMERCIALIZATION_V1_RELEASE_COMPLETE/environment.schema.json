{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dispatch.auricworks.ai/schemas/fs13000/environment.schema.json",
  "title": "FS-13001 environment schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "tenant_id",
    "object_type",
    "version",
    "status",
    "classification",
    "owner_id",
    "created_at",
    "updated_at",
    "source_refs",
    "evidence_refs",
    "approval_refs",
    "audit_ref"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 3
    },
    "tenant_id": {
      "type": "string",
      "minLength": 3
    },
    "object_type": {
      "const": "environment"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "provisioning",
        "validating",
        "active",
        "degraded",
        "suspended",
        "retired"
      ]
    },
    "classification": {
      "type": "string",
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted",
        "synthetic"
      ]
    },
    "owner_id": {
      "type": "string",
      "minLength": 3
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "effective_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "approval_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "control_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "audit_ref": {
      "type": "string"
    },
    "correlation_id": {
      "type": "string"
    },
    "idempotency_key": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "scope": {
      "type": "object",
      "additionalProperties": true
    },
    "economics": {
      "type": "object",
      "additionalProperties": true
    },
    "metrics": {
      "type": "object",
      "additionalProperties": true
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_action": {
      "type": [
        "string",
        "null"
      ]
    },
    "due_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "data_state": {
      "type": "string",
      "enum": [
        "unknown",
        "stale",
        "inferred",
        "attested",
        "verified",
        "synthetic"
      ]
    }
  }
}