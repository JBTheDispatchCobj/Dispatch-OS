{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dispatch://schemas/executive/1.0.0",
  "title": "Executive",
  "type": "object",
  "required": [
    "executive_id",
    "full_name",
    "current_roles",
    "profile_status"
  ],
  "properties": {
    "executive_id": {
      "type": "string",
      "pattern": "^PER-[0-9A-Z-]+$"
    },
    "full_name": {
      "type": "string",
      "minLength": 1
    },
    "preferred_name": {
      "type": "string"
    },
    "public_biography": {
      "type": "string"
    },
    "current_roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "institution_id",
          "title",
          "status"
        ],
        "properties": {
          "institution_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "department": {
            "type": "string"
          },
          "start_date": {
            "type": [
              "string",
              "null"
            ],
            "format": "date"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "interim",
              "announced",
              "inactive"
            ]
          },
          "source_reference": {
            "type": "string"
          },
          "confidence": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low",
              "unknown"
            ]
          }
        }
      }
    },
    "authority_records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "authority_type",
          "scope",
          "status"
        ],
        "properties": {
          "authority_type": {
            "type": "string"
          },
          "scope": {
            "type": "string"
          },
          "threshold": {
            "type": [
              "number",
              "null"
            ]
          },
          "currency": {
            "type": [
              "string",
              "null"
            ]
          },
          "effective_from": {
            "type": [
              "string",
              "null"
            ],
            "format": "date"
          },
          "expires_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "inactive",
              "expired",
              "inferred"
            ]
          },
          "evidence_id": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "relationship_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "profile_status": {
      "type": "string",
      "enum": [
        "discovered",
        "seeded",
        "verified",
        "active",
        "stale",
        "archived"
      ]
    },
    "visibility": {
      "type": "string",
      "enum": [
        "public",
        "tenant_internal",
        "confidential",
        "restricted",
        "synthetic"
      ]
    }
  },
  "additionalProperties": false
}