{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Graph Inference Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "inference_id",
    "inference_type",
    "input_signal_ids",
    "method",
    "method_version",
    "confidence",
    "status",
    "created_at",
    "expires_at"
  ],
  "properties": {
    "inference_id": {
      "type": "string"
    },
    "inference_type": {
      "type": "string"
    },
    "input_signal_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "method": {
      "type": "string"
    },
    "method_version": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "status": {
      "enum": [
        "proposed",
        "accepted",
        "rejected",
        "expired",
        "superseded"
      ]
    },
    "reviewer_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "explanation": {
      "type": "string"
    }
  }
}