{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Graph Population Job",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "population_job_id",
    "tenant_id",
    "population_manifest_id",
    "status",
    "idempotency_key",
    "started_at",
    "metrics"
  ],
  "properties": {
    "population_job_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "population_manifest_id": {
      "type": "string"
    },
    "status": {
      "enum": [
        "queued",
        "running",
        "paused",
        "completed",
        "completed_with_exceptions",
        "failed",
        "cancelled"
      ]
    },
    "idempotency_key": {
      "type": "string"
    },
    "checkpoint": {
      "type": [
        "string",
        "null"
      ]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "metrics": {
      "type": "object"
    },
    "error_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}