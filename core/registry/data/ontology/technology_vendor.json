{
  "key": "ontology:technology_vendor",
  "label": "Technology & Vendor Ontology",
  "version": 1,
  "domain": "financial_services",
  "notes": "Volume XI Sprint-1 pack (ADR-0014/0015). Operational ontology for the institution's technology stack and third-party ecosystem: systems of record (core processor, LOS, CRM, ERP, accounting, data warehouse, IdP), integration primitives (API, connector, webhook, marketplace package, SDK), deployed AI models, and the vendor lifecycle (vendor/partner, MSA/SLA/contract, implementation, renewal, support tickets, third-party risk assessment). This is the substrate the Cooperative Markets innovation graph (startup/product/integration/vendor_evaluation) hooks into. The technology and vendors_partners families both define api and connector under distinct schema_refs; both are enriched here without collision. Relationship targets are catalog schema_refs (closed graph). Third-party risk conclusions persist evidence, source, confidence, and lineage — never weights alone (NCUA third-party due-diligence guidance; DOCTRINE). Connector keys are forward references into the Connector Registry (Volume IX).",
  "ontologies": [
    {
      "object": "financial_services:technology:core_processor",
      "label": "Core Processor (Core Banking System)",
      "notes": "The system of record for accounts, members, and transactions — the institution's most critical vendor relationship (e.g. Symitar/Episys, DNA, Keystone, Corelation).",
      "relationships": [
        { "predicate": "system_of_record_for", "target": "financial_services:institutions:federal_credit_union", "cardinality": "one" },
        { "predicate": "provided_by", "target": "financial_services:vendors_partners:vendor", "cardinality": "one" },
        { "predicate": "exposes", "target": "financial_services:technology:api", "cardinality": "many" },
        { "predicate": "assessed_by", "target": "financial_services:vendors_partners:risk_assessment", "cardinality": "one" },
        { "predicate": "governed_by", "target": "financial_services:vendors_partners:msa", "cardinality": "one" },
        { "predicate": "poses", "target": "financial_services:risk:vendor_risk", "cardinality": "one" }
      ],
      "lifecycle": {
        "initial": "evaluation",
        "states": [
          { "key": "evaluation", "label": "Evaluation" },
          { "key": "contracted", "label": "Contracted" },
          { "key": "implementation", "label": "Implementation / Conversion" },
          { "key": "live", "label": "Live" },
          { "key": "sunset", "label": "Sunset / Migration", "terminal": true }
        ],
        "transitions": [
          { "from": "evaluation", "to": "contracted", "on": "vendor_selected" },
          { "from": "contracted", "to": "implementation", "on": "conversion_kickoff" },
          { "from": "implementation", "to": "live", "on": "core_conversion_go_live" },
          { "from": "live", "to": "sunset", "on": "replacement_decision" }
        ]
      },
      "kpis": [
        { "key": "uptime", "label": "Core Uptime", "unit": "%", "threshold": ">= 99.9%" },
        { "key": "transaction_throughput", "label": "Transaction Throughput", "unit": "tps" },
        { "key": "batch_completion", "label": "Nightly Batch Completion", "unit": "% on-time" },
        { "key": "incident_count", "label": "Sev-1 Incidents", "unit": "count" }
      ],
      "required_documents": [
        { "key": "core_msa", "label": "Core Processing MSA", "required": true },
        { "key": "core_sla", "label": "Core SLA", "required": true },
        { "key": "soc2", "label": "SOC 2 Type II Report", "required": true },
        { "key": "bcp_dr", "label": "BCP / DR Plan", "required": true }
      ],
      "connectors": [
        { "key": "connector:core_banking", "label": "Core Banking", "role": "system_of_record" }
      ]
    },
