{
  "key": "ontology:credit_union",
  "label": "Credit Union Ontology",
  "version": 1,
  "domain": "financial_services",
  "notes": "Volume XI anchor pack (ADR-0014). Operational ontology for the credit-union core — the Cooperative Markets first-product domain. Enriches Object Registry classes by schema_ref with relationships, lifecycle, KPIs, required documents, and connectors. Relationship targets are catalog schema_refs (closed graph). Connector keys are forward references into the Connector Registry (Volume IX).",
  "ontologies": [
    {
      "object": "financial_services:institutions:federal_credit_union",
      "label": "Federal Credit Union",
      "relationships": [
        { "predicate": "regulated_by", "target": "financial_services:regulation:ncua", "cardinality": "one", "description": "Chartered and supervised by the NCUA; shares insured by the NCUSIF." },
        { "predicate": "serves", "target": "financial_services:people:member", "cardinality": "many", "description": "Member-owners within the field of membership." },
        { "predicate": "employs", "target": "financial_services:people:loan_officer", "cardinality": "many" },
        { "predicate": "offers", "target": "financial_services:lending_products:auto_loan", "cardinality": "many" },
        { "predicate": "offers", "target": "financial_services:lending_products:consumer_loan", "cardinality": "many" },
        { "predicate": "offers", "target": "financial_services:lending_products:mortgage", "cardinality": "many" },
        { "predicate": "offers", "target": "financial_services:deposit_products:savings", "cardinality": "many" },
        { "predicate": "offers", "target": "financial_services:deposit_products:certificate", "cardinality": "many" },
        { "predicate": "files", "target": "financial_services:regulation:call_reports", "cardinality": "many" },
        { "predicate": "undergoes", "target": "financial_services:regulation:examinations", "cardinality": "many" },
        { "predicate": "subject_to", "target": "financial_services:compliance:bsa", "cardinality": "one" },
        { "predicate": "affiliated_with", "target": "financial_services:institutions:credit_union_service_organization_cuso", "cardinality": "many" }
      ],
      "lifecycle": {
        "initial": "chartered",
        "states": [
          { "key": "chartered", "label": "Chartered" },
          { "key": "operating", "label": "Operating" },
          { "key": "troubled", "label": "Troubled (CAMELS 4-5 / net worth < 6%)" },
          { "key": "conserved", "label": "Conserved" },
          { "key": "merged", "label": "Merged", "terminal": true },
          { "key": "liquidated", "label": "Liquidated", "terminal": true }
        ],
        "transitions": [
          { "from": "chartered", "to": "operating", "on": "commences_operations" },
          { "from": "operating", "to": "troubled", "on": "net_worth_or_camels_deteriorates" },
          { "from": "troubled", "to": "operating", "on": "rehabilitated" },
          { "from": "troubled", "to": "conserved", "on": "ncua_conservatorship" },
          { "from": "troubled", "to": "merged", "on": "voluntary_or_assisted_merger" },
          { "from": "conserved", "to": "liquidated", "on": "involuntary_liquidation" }
        ]
      },
      "kpis": [
        { "key": "net_worth_ratio", "label": "Net Worth Ratio", "formula": "net_worth / total_assets", "unit": "%", "threshold": ">= 7% well-capitalized; < 6% undercapitalized (PCA)" },
        { "key": "roa", "label": "Return on Average Assets", "formula": "net_income / average_assets", "unit": "%", "threshold": "peer-relative; positive trend" },
        { "key": "loan_to_share", "label": "Loan-to-Share Ratio", "formula": "total_loans / total_shares", "unit": "%", "threshold": "70-90% typical" },
        { "key": "delinquency_ratio", "label": "Delinquency Ratio", "formula": "delinquent_loans / total_loans", "unit": "%", "threshold": "< 1% healthy" },
        { "key": "net_charge_off_ratio", "label": "Net Charge-Off Ratio", "formula": "net_charge_offs / average_loans", "unit": "%" },
        { "key": "operating_expense_ratio", "label": "Operating Expense Ratio", "formula": "operating_expenses / average_assets", "unit": "%" },
        { "key": "membership_growth", "label": "Membership Growth", "formula": "(members_end - members_start) / members_start", "unit": "%" }
      ],
      "required_documents": [
        { "key": "charter", "label": "Federal Charter", "required": true },
        { "key": "bylaws", "label": "Bylaws", "required": true },
        { "key": "field_of_membership", "label": "Field of Membership Definition", "required": true },
        { "key": "call_report_5300", "label": "NCUA 5300 Call Report", "required": true },
        { "key": "bsa_aml_program", "label": "BSA/AML Program", "required": true },
        { "key": "investment_policy", "label": "Investment Policy", "required": true }
      ],
      "connectors": [
        { "key": "connector:core_banking", "label": "Core Banking / Core Processor", "role": "system_of_record" },
        { "key": "connector:ncua_call_reports", "label": "NCUA Call Report Feed", "role": "ingest" },
        { "key": "connector:los", "label": "Loan Origination System", "role": "enrichment" }
      ]
    },
