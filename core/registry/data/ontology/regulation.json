        { "predicate": "regulates", "target": "financial_services:institutions:community_bank", "cardinality": "many" },
        { "predicate": "regulates", "target": "financial_services:institutions:savings_bank", "cardinality": "many" },
        { "predicate": "regulates", "target": "financial_services:institutions:industrial_bank", "cardinality": "many" },
        { "predicate": "insures", "target": "financial_services:deposit_products:checking", "cardinality": "many", "description": "DIF deposit insurance (the bank analogue of the NCUSIF)." },
        { "predicate": "conducts", "target": "financial_services:regulation:examinations", "cardinality": "many" },
        { "predicate": "assesses", "target": "financial_services:compliance:cra", "cardinality": "many" },
        { "predicate": "issues", "target": "financial_services:regulation:consent_orders", "cardinality": "many" }
      ],
      "kpis": [
        { "key": "camels_composite", "label": "CAMELS Composite (supervised)", "unit": "1-5" },
        { "key": "dif_reserve_ratio", "label": "DIF Reserve Ratio", "unit": "%", "threshold": ">= 1.35% statutory minimum" }
