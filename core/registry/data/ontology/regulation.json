    {
      "object": "financial_services:regulation:consent_orders",
      "label": "Consent Order / Enforcement Action",
      "notes": "A formal enforcement action (consent order, LUA, C&D, civil money penalty) resolving supervisory findings. Public actions are a market-intelligence signal; each links to its issuing regulator, subject institution, and remediation obligations.",
      "relationships": [
        { "predicate": "issued_by", "target": "financial_services:regulation:cfpb", "cardinality": "one" },
        { "predicate": "issued_by", "target": "financial_services:regulation:ncua", "cardinality": "one" },
        { "predicate": "subject", "target": "financial_services:institutions:federal_credit_union", "cardinality": "one" },
        { "predicate": "results_from", "target": "financial_services:regulation:examinations", "cardinality": "one" },
        { "predicate": "requires", "target": "financial_services:operations:exception", "cardinality": "many", "description": "Remediation obligations tracked as owned corrective actions." },
        { "predicate": "informs", "target": "financial_services:risk:compliance_risk", "cardinality": "one" }
      ],
      "lifecycle": {
        "initial": "issued",
        "states": [
          { "key": "issued", "label": "Issued" },
          { "key": "remediation", "label": "Remediation" },
          { "key": "compliance_validated", "label": "Compliance Validated" },
          { "key": "terminated", "label": "Terminated", "terminal": true }
        ],
        "transitions": [
          { "from": "issued", "to": "remediation", "on": "action_plan_accepted" },
          { "from": "remediation", "to": "compliance_validated", "on": "obligations_met" },
          { "from": "compliance_validated", "to": "terminated", "on": "order_lifted" }
